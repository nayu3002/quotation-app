# QuoteFlow V2 — Web App Environment Variables
# Copy to .env and fill in your values

# ─── SUPABASE ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL=your_postgresql_connection_string_from_supabase

# ─── STRIPE ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# ─── OPENAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_key

# ─── RESEND ──────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL=noreply@quoteflow.app
RESEND_FROM_NAME=QuoteFlow

# ─── UPLOADTHING ─────────────────────────────────────────────────────────────
UPLOADTHING_SECRET=sk_live_your_key
UPLOADTHING_APP_ID=your_app_id

# ─── UPSTASH REDIS ───────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# ─── APP ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=QuoteFlow
SUPER_ADMIN_SECRET=change_me_in_production_use_random_256bit_string
